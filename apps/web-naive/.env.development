# 端口号
VITE_PORT=5888

VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=/api

# 是否开启 Nitro Mock服务，true 为开启，false 为关闭
VITE_NITRO_MOCK=true

# Nitro Mock 包路径，$/xxx 解析为 <外层 monorepo 根>/xxx
# 例如 $/apps/backend-mock-template → <仓库根>/apps/backend-mock-template
VITE_NITRO_MOCK_SERVER_PACKAGE=$/apps/backend-mock-template

# 是否打开 devtools，true 为打开，false 为关闭
VITE_DEVTOOLS=false

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true
