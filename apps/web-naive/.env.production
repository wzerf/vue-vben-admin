VITE_BASE=/

# 接口地址
VITE_GLOB_API_URL=https://mock-napi.vben.pro/api

# 是否开启压缩，可以设置为 none, brotli, gzip
VITE_COMPRESS=none

# 是否开启 PWA
VITE_PWA=false

# vue-router 的模式
VITE_ROUTER_HISTORY=hash

# 是否注入全局loading
VITE_INJECT_APP_LOADING=true

# 当前应用平台标识（用于字典类型/字典项默认筛选）
VITE_APP_PLATFORM=vue-admin

# 打包后是否生成dist.zip
VITE_ARCHIVER=true
